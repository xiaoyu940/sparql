@base <http://example.org/mapping/> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .
@prefix ex: <http://example.org/> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix geo: <http://www.opengis.net/ont/geosparql#> .

<#EmployeeMapping>
    a rr:TriplesMap;
    rr:logicalTable [ rr:tableName "employees" ];
    rr:subjectMap [
        rr:template "http://example.org/emp{employee_id}";
        rr:class ex:Employee
    ];
    rr:predicateObjectMap [
        rr:predicate ex:employee_id;
        rr:objectMap [ rr:column "employee_id" ]
    ];
    rr:predicateObjectMap [
        rr:predicate ex:first_name;
        rr:objectMap [ rr:column "first_name" ]
    ];
